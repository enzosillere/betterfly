<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bettefly Festival — 13 Juin 2026 · Rueil-Malmaison</title>
  <meta name="description" content="Bettefly Festival — Le festival électro/pop de Rueil-Malmaison. 13 juin 2026 au Parc des Bords de Seine. Organisé par le Rotaract Club de Rueil-Malmaison." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
  <style>
    /* ─── CSS VARIABLES ─────────────────────────────────────── */
    :root {
      --neon-violet: #bf00ff;
      --neon-pink:   #ff2d78;
      --neon-blue:   #00c8ff;
      --neon-lime:   #c6ff00;
      --bg-dark:     #05040e;
      --bg-mid:      #0a0818;
      --bg-card:     #110f22;
      --bg-card2:    #0d0b1e;
      --text-main:   #f0ecff;
      --text-muted:  #8a7faa;
      --border:      rgba(191,0,255,0.18);
      --glow-v:      0 0 30px rgba(191,0,255,0.45);
      --glow-p:      0 0 30px rgba(255,45,120,0.45);
      --glow-b:      0 0 30px rgba(0,200,255,0.35);
      --font-display: 'Bebas Neue', sans-serif;
      --font-mono:    'Space Mono', monospace;
      --font-body:    'DM Sans', sans-serif;
    }

    /* ─── RESET & BASE ──────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg-dark);
      color: var(--text-main);
      font-family: var(--font-body);
      font-weight: 300;
      line-height: 1.7;
      overflow-x: hidden;
    }
    ::selection { background: var(--neon-violet); color: #fff; }

    img { display: block; max-width: 100%; }
    a  { color: inherit; text-decoration: none; }

    /* ─── SCROLLBAR ─────────────────────────────────────────── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg-dark); }
    ::-webkit-scrollbar-thumb { background: var(--neon-violet); border-radius: 3px; }

    /* ─── NOISE OVERLAY ─────────────────────────────────────── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.028;
      pointer-events: none;
      z-index: 9999;
    }

    /* ─── NAV ───────────────────────────────────────────────── */
    #nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 5vw;
      height: 72px;
      transition: background 0.4s, backdrop-filter 0.4s;
    }
    #nav.scrolled {
      background: rgba(5,4,14,0.88);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 2rem;
      letter-spacing: 0.04em;
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink), var(--neon-blue));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--neon-pink); }
    .nav-cta {
      background: linear-gradient(135deg, var(--neon-violet), var(--neon-pink));
      color: #fff !important;
      padding: 0.45rem 1.2rem;
      border-radius: 100px;
      font-size: 0.72rem !important;
      letter-spacing: 0.1em;
      transition: box-shadow 0.3s, transform 0.2s !important;
    }
    .nav-cta:hover {
      box-shadow: var(--glow-p);
      transform: translateY(-1px);
      color: #fff !important;
    }
    .burger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
    }
    .burger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text-main);
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
    }
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(5,4,14,0.97);
      backdrop-filter: blur(24px);
      z-index: 999;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2.5rem;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-family: var(--font-display);
      font-size: 2.5rem;
      letter-spacing: 0.06em;
      color: var(--text-main);
      transition: color 0.2s;
    }
    .mobile-menu a:hover { color: var(--neon-pink); }
    .mobile-close {
      position: absolute;
      top: 24px; right: 5vw;
      font-size: 2rem;
      cursor: pointer;
      background: none;
      border: none;
      color: var(--text-muted);
    }

    /* ─── BUTTONS ───────────────────────────────────────────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.85rem 2.2rem;
      border-radius: 100px;
      border: none;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.3s;
    }
    .btn:hover { transform: translateY(-2px); }
    .btn-primary {
      background: linear-gradient(135deg, var(--neon-violet) 0%, var(--neon-pink) 100%);
      color: #fff;
      box-shadow: 0 0 0 rgba(255,45,120,0);
    }
    .btn-primary:hover { box-shadow: 0 8px 40px rgba(255,45,120,0.5); }
    .btn-outline {
      background: transparent;
      color: var(--text-main);
      border: 1px solid var(--border);
    }
    .btn-outline:hover {
      border-color: var(--neon-blue);
      box-shadow: var(--glow-b);
      color: var(--neon-blue);
    }
    .btn-lime {
      background: var(--neon-lime);
      color: #050408;
    }
    .btn-lime:hover { box-shadow: 0 8px 40px rgba(198,255,0,0.4); }

    /* ─── SECTION UTILITIES ─────────────────────────────────── */
    section { position: relative; }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 5vw;
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--neon-blue);
      margin-bottom: 1rem;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 8vw, 6rem);
      line-height: 0.92;
      letter-spacing: 0.02em;
      margin-bottom: 1.5rem;
    }
    .grad-text {
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .grad-text-b {
      background: linear-gradient(90deg, var(--neon-blue), var(--neon-lime));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .divider {
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink));
      margin: 0 auto 3rem;
      border-radius: 2px;
    }

    /* ─── HERO ──────────────────────────────────────────────── */
    #hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 120px 5vw 80px;
      overflow: hidden;
    }
    /* Animated background blobs */
    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      overflow: hidden;
    }
    .blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.35;
      animation: float 8s ease-in-out infinite alternate;
    }
    .blob-1 {
      width: 55vw; height: 55vw;
      top: -15%; left: -10%;
      background: var(--neon-violet);
      animation-delay: 0s;
    }
    .blob-2 {
      width: 40vw; height: 40vw;
      bottom: -10%; right: -5%;
      background: var(--neon-pink);
      animation-delay: -3s;
    }
    .blob-3 {
      width: 30vw; height: 30vw;
      top: 30%; left: 60%;
      background: var(--neon-blue);
      opacity: 0.22;
      animation-delay: -6s;
    }
    @keyframes float {
      from { transform: translate(0,0) scale(1); }
      to   { transform: translate(4%, 6%) scale(1.07); }
    }
    /* Grid lines overlay */
    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(191,0,255,0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(191,0,255,0.06) 1px, transparent 1px);
      background-size: 60px 60px;
      z-index: 0;
    }
    .hero-content { position: relative; z-index: 2; max-width: 920px; }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--neon-lime);
      background: rgba(198,255,0,0.08);
      border: 1px solid rgba(198,255,0,0.2);
      padding: 0.4rem 1.1rem;
      border-radius: 100px;
      margin-bottom: 2rem;
      animation: fadeUp 0.8s both;
    }
    .dot-blink {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--neon-lime);
      animation: blink 1.2s infinite;
    }
    @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.2;} }
    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(5rem, 16vw, 11rem);
      line-height: 0.88;
      letter-spacing: 0.02em;
      animation: fadeUp 0.8s 0.1s both;
      margin-bottom: 0.4rem;
    }
    .hero-sub {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 4vw, 2.6rem);
      letter-spacing: 0.18em;
      color: var(--text-muted);
      animation: fadeUp 0.8s 0.2s both;
      margin-bottom: 2.5rem;
    }
    .hero-desc {
      font-size: 1.05rem;
      color: var(--text-muted);
      max-width: 540px;
      margin: 0 auto 3rem;
      animation: fadeUp 0.8s 0.3s both;
    }
    .hero-ctas {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      animation: fadeUp 0.8s 0.4s both;
      margin-bottom: 4rem;
    }
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(24px); }
      to   { opacity:1; transform:translateY(0); }
    }

    /* ─── COUNTDOWN ─────────────────────────────────────────── */
    .countdown-wrapper {
      animation: fadeUp 0.8s 0.5s both;
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .countdown-block {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 90px;
    }
    .countdown-num {
      font-family: var(--font-display);
      font-size: clamp(3rem, 8vw, 5.5rem);
      line-height: 1;
      background: linear-gradient(135deg, #fff 0%, var(--neon-violet) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 16px rgba(191,0,255,0.6));
    }
    .countdown-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-top: 0.2rem;
    }
    .countdown-sep {
      font-family: var(--font-display);
      font-size: 3rem;
      color: var(--neon-violet);
      opacity: 0.4;
      align-self: flex-start;
      margin-top: 0.4rem;
    }
    /* scroll indicator */
    .scroll-hint {
      position: absolute;
      bottom: 2.5rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      text-transform: uppercase;
      z-index: 2;
    }
    .scroll-arrow {
      width: 20px; height: 20px;
      border-right: 2px solid var(--text-muted);
      border-bottom: 2px solid var(--text-muted);
      transform: rotate(45deg);
      animation: bounce 1.6s infinite;
    }
    @keyframes bounce { 0%,100%{transform:rotate(45deg) translate(0,0);} 50%{transform:rotate(45deg) translate(4px,4px);} }

    /* ─── VIBE STRIP ────────────────────────────────────────── */
    .ticker-wrap {
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink), var(--neon-blue), var(--neon-lime), var(--neon-violet));
      background-size: 400% 100%;
      animation: shimmer 6s linear infinite;
      padding: 0.9rem 0;
      overflow: hidden;
      white-space: nowrap;
    }
    @keyframes shimmer { to { background-position: -400% 0; } }
    .ticker-inner {
      display: inline-flex;
      gap: 4rem;
      animation: ticker 25s linear infinite;
    }
    .ticker-inner span {
      font-family: var(--font-display);
      font-size: 1.1rem;
      letter-spacing: 0.12em;
      color: #050408;
    }
    @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ─── LINEUP ────────────────────────────────────────────── */
    #lineup {
      padding: 120px 0;
      background: var(--bg-mid);
    }
    .lineup-header { text-align: center; margin-bottom: 4rem; }
    .artists-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .artist-card {
      position: relative;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
      cursor: pointer;
    }
    .artist-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(191,0,255,0.07) 0%, transparent 60%);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .artist-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--glow-v);
      border-color: rgba(191,0,255,0.45);
    }
    .artist-card:hover::before { opacity: 1; }
    .artist-time {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      color: var(--neon-blue);
      margin-bottom: 0.6rem;
    }
    .artist-name {
      font-family: var(--font-display);
      font-size: 2rem;
      letter-spacing: 0.04em;
      margin-bottom: 0.4rem;
    }
    .artist-genre {
      font-size: 0.82rem;
      color: var(--text-muted);
    }
    .artist-badge {
      position: absolute;
      top: 1.5rem;
      right: 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.25rem 0.7rem;
      border-radius: 100px;
    }
    .badge-headliner { background: rgba(255,45,120,0.18); color: var(--neon-pink); border: 1px solid rgba(255,45,120,0.35); }
    .badge-dj        { background: rgba(0,200,255,0.12); color: var(--neon-blue); border: 1px solid rgba(0,200,255,0.3); }
    .badge-pop       { background: rgba(191,0,255,0.12); color: var(--neon-violet); border: 1px solid rgba(191,0,255,0.3); }
    .artist-avatar {
      width: 56px; height: 56px;
      border-radius: 50%;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      font-family: var(--font-display);
    }
    .av-1 { background: linear-gradient(135deg, #3d0085, #bf00ff); }
    .av-2 { background: linear-gradient(135deg, #85003d, #ff2d78); }
    .av-3 { background: linear-gradient(135deg, #005580, #00c8ff); }
    .av-4 { background: linear-gradient(135deg, #3d8500, #c6ff00); color:#050408; }
    .av-5 { background: linear-gradient(135deg, #800055, #ff2d78); }
    .av-6 { background: linear-gradient(135deg, #004080, #00c8ff); }
    .av-7 { background: linear-gradient(135deg, #550085, #bf00ff); }
    .av-8 { background: linear-gradient(135deg, #800022, #ff2d78); }

    /* stages */
    .stages-tabs {
      display: flex;
      gap: 1rem;
      margin-bottom: 2.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    .stage-tab {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 0.5rem 1.4rem;
      border-radius: 100px;
      border: 1px solid var(--border);
      cursor: pointer;
      background: transparent;
      color: var(--text-muted);
      transition: all 0.2s;
    }
    .stage-tab.active,
    .stage-tab:hover {
      background: linear-gradient(135deg, var(--neon-violet), var(--neon-pink));
      color: #fff;
      border-color: transparent;
    }

    /* ─── BILLETTERIE ───────────────────────────────────────── */
    #tickets {
      padding: 120px 0;
      background: var(--bg-dark);
    }
    .tickets-header { text-align: center; margin-bottom: 4rem; }
    .urgency-banner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      background: rgba(255,45,120,0.1);
      border: 1px solid rgba(255,45,120,0.3);
      border-radius: 100px;
      padding: 0.6rem 1.5rem;
      margin-bottom: 3rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      color: var(--neon-pink);
      animation: pulse-border 2s infinite;
    }
    @keyframes pulse-border {
      0%,100%{border-color:rgba(255,45,120,0.3);}
      50%{border-color:rgba(255,45,120,0.7);}
    }
    .ticket-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
      gap: 1.5rem;
      align-items: start;
    }
    .ticket-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.5rem 2rem;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .ticket-card:hover { transform: translateY(-6px); }
    .ticket-card.featured {
      border-color: var(--neon-pink);
      box-shadow: 0 0 40px rgba(255,45,120,0.2);
      transform: scale(1.04);
    }
    .ticket-card.featured:hover { transform: scale(1.04) translateY(-6px); }
    .featured-label {
      position: absolute;
      top: 0; left: 0; right: 0;
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink));
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 0.4rem;
      color: #fff;
    }
    .ticket-type {
      font-family: var(--font-display);
      font-size: 2rem;
      letter-spacing: 0.06em;
      margin-bottom: 0.3rem;
    }
    .ticket-price {
      font-family: var(--font-display);
      font-size: 3.5rem;
      line-height: 1;
      margin: 1rem 0 0.3rem;
    }
    .ticket-price sub {
      font-family: var(--font-mono);
      font-size: 1rem;
      vertical-align: middle;
    }
    .ticket-strike {
      font-size: 0.9rem;
      color: var(--text-muted);
      text-decoration: line-through;
      margin-bottom: 1.2rem;
    }
    .ticket-perks {
      list-style: none;
      text-align: left;
      margin: 1.5rem 0 2rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }
    .ticket-perks li {
      font-size: 0.88rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .ticket-perks li::before {
      content: '✓';
      width: 18px; height: 18px;
      border-radius: 50%;
      background: rgba(0,200,255,0.15);
      color: var(--neon-blue);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      flex-shrink: 0;
    }
    .stock-bar-wrap {
      margin-bottom: 1.5rem;
    }
    .stock-bar-label {
      display: flex;
      justify-content: space-between;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--text-muted);
      margin-bottom: 0.4rem;
    }
    .stock-bar {
      height: 4px;
      background: rgba(255,255,255,0.08);
      border-radius: 2px;
      overflow: hidden;
    }
    .stock-fill {
      height: 100%;
      border-radius: 2px;
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink));
      transition: width 1s cubic-bezier(0.4,0,0.2,1);
    }

    /* ─── AMBIANCE / GALLERY ────────────────────────────────── */
    #vibes {
      padding: 120px 0;
      background: var(--bg-mid);
      overflow: hidden;
    }
    .vibes-header { text-align: center; margin-bottom: 4rem; }
    .vibes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, 260px);
      gap: 1rem;
    }
    .vibe-item {
      border-radius: 16px;
      overflow: hidden;
      position: relative;
    }
    .vibe-item:first-child { grid-row: span 2; }
    .vibe-box {
      width: 100%; height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      transition: transform 0.5s;
      position: relative;
      overflow: hidden;
    }
    .vibe-item:hover .vibe-box { transform: scale(1.05); }
    .vb-1 { background: linear-gradient(135deg, #1a0040 0%, #5500a0 50%, #bf00ff 100%); }
    .vb-2 { background: linear-gradient(135deg, #3d0020 0%, #a00050 50%, #ff2d78 100%); }
    .vb-3 { background: linear-gradient(135deg, #001540 0%, #003880 50%, #00c8ff 100%); }
    .vb-4 { background: linear-gradient(135deg, #0d1a00 0%, #336600 50%, #c6ff00 100%); }
    .vb-5 { background: linear-gradient(135deg, #2a0040 0%, #7700bf 50%, #ff00aa 100%); }
    .vibe-overlay {
      position: absolute;
      inset: 0;
      background: rgba(5,4,14,0.55);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      padding: 1.5rem;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .vibe-item:hover .vibe-overlay { opacity: 1; }
    .vibe-overlay p {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #fff;
    }
    /* Simulated concert lights */
    .vibe-lights {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }
    .light-beam {
      position: absolute;
      bottom: 0;
      width: 3px;
      background: linear-gradient(to top, rgba(255,255,255,0.6), transparent);
      border-radius: 2px;
      animation: beam 3s ease-in-out infinite alternate;
    }
    @keyframes beam { from{transform:rotate(-15deg);} to{transform:rotate(15deg);} }
    .lb1{left:20%;height:60%;animation-delay:0s;}
    .lb2{left:40%;height:75%;animation-delay:-1s;}
    .lb3{left:60%;height:65%;animation-delay:-2s;}
    .lb4{left:80%;height:55%;animation-delay:-0.5s;}

    /* ─── INFOS PRATIQUES ───────────────────────────────────── */
    #infos {
      padding: 120px 0;
      background: var(--bg-dark);
    }
    .infos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .info-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .info-card:hover {
      border-color: var(--neon-blue);
      box-shadow: var(--glow-b);
    }
    .info-icon {
      font-size: 2rem;
      margin-bottom: 1rem;
    }
    .info-card h3 {
      font-family: var(--font-display);
      font-size: 1.4rem;
      letter-spacing: 0.05em;
      margin-bottom: 0.8rem;
    }
    .info-card p, .info-card li {
      font-size: 0.88rem;
      color: var(--text-muted);
      line-height: 1.8;
    }
    .info-card ul { padding-left: 1.1rem; }
    .map-placeholder {
      margin-top: 3rem;
      height: 300px;
      border-radius: 20px;
      border: 1px solid var(--border);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg-card);
      position: relative;
    }
    .map-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,200,255,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,200,255,0.05) 1px, transparent 1px);
      background-size: 30px 30px;
    }
    .map-label {
      position: relative;
      z-index: 2;
      text-align: center;
    }
    .map-label p { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); letter-spacing: 0.1em; }
    .map-pin {
      font-size: 3rem;
      display: block;
      filter: drop-shadow(0 0 16px var(--neon-blue));
      animation: float 2s ease-in-out infinite alternate;
    }

    /* ─── ABOUT ─────────────────────────────────────────────── */
    #about {
      padding: 120px 0;
      background: var(--bg-mid);
    }
    .about-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }
    .about-visual {
      position: relative;
      height: 420px;
    }
    .about-ring {
      position: absolute;
      border-radius: 50%;
      border: 2px solid;
      animation: spin 20s linear infinite;
    }
    .ar1 { inset: 0; border-color: rgba(191,0,255,0.3); animation-direction: normal; }
    .ar2 { inset: 20px; border-color: rgba(255,45,120,0.2); animation-direction: reverse; animation-duration: 28s; }
    .ar3 { inset: 50px; border-color: rgba(0,200,255,0.2); animation-duration: 35s; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .about-center {
      position: absolute;
      inset: 80px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(191,0,255,0.25) 0%, transparent 70%);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      text-align: center;
    }
    .about-center-logo {
      font-family: var(--font-display);
      font-size: 3.5rem;
      background: linear-gradient(135deg, var(--neon-violet), var(--neon-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .about-center-sub {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      color: var(--text-muted);
      margin-top: 0.3rem;
    }
    .about-text h2 { margin-bottom: 1.5rem; }
    .about-text p {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin-bottom: 1.2rem;
    }
    .values-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-top: 2rem;
    }
    .value-pill {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.4rem 1rem;
      border-radius: 100px;
      border: 1px solid;
    }
    .vp-v { border-color: rgba(191,0,255,0.4); color: var(--neon-violet); }
    .vp-p { border-color: rgba(255,45,120,0.4); color: var(--neon-pink); }
    .vp-b { border-color: rgba(0,200,255,0.4); color: var(--neon-blue); }
    .vp-l { border-color: rgba(198,255,0,0.4); color: var(--neon-lime); }

    /* ─── PARTENAIRES ───────────────────────────────────────── */
    #partners {
      padding: 80px 0;
      background: var(--bg-dark);
      border-top: 1px solid var(--border);
    }
    .partners-label {
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 3rem;
    }
    .partners-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      justify-content: center;
      align-items: center;
    }
    .partner-logo {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.2rem 2rem;
      font-family: var(--font-display);
      font-size: 1.2rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      transition: color 0.3s, border-color 0.3s, box-shadow 0.3s;
      cursor: default;
    }
    .partner-logo:hover {
      color: var(--text-main);
      border-color: var(--neon-violet);
      box-shadow: var(--glow-v);
    }

    /* ─── CONTACT ───────────────────────────────────────────── */
    #contact {
      padding: 120px 0;
      background: var(--bg-mid);
    }
    .contact-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
    .contact-info h2 { margin-bottom: 1.5rem; }
    .contact-info p { color: var(--text-muted); font-size: 0.95rem; margin-bottom: 2rem; }
    .contact-links { display: flex; flex-direction: column; gap: 1rem; }
    .contact-link {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      transition: color 0.2s;
    }
    .contact-link:hover { color: var(--neon-blue); }
    .contact-link-icon {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--bg-card);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 1rem;
    }
    .contact-form {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.5rem;
    }
    .form-group {
      margin-bottom: 1.2rem;
    }
    .form-group label {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.4rem;
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.8rem 1rem;
      color: var(--text-main);
      font-family: var(--font-body);
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      border-color: var(--neon-violet);
      box-shadow: 0 0 0 3px rgba(191,0,255,0.12);
    }
    .form-group textarea { resize: vertical; min-height: 110px; }
    .form-group select option { background: var(--bg-card); }
    .form-success {
      display: none;
      text-align: center;
      padding: 2rem;
    }
    .form-success.show { display: block; }
    .form-success h3 {
      font-family: var(--font-display);
      font-size: 2rem;
      color: var(--neon-lime);
      margin-bottom: 0.5rem;
    }

    /* ─── FOOTER ────────────────────────────────────────────── */
    footer {
      background: var(--bg-dark);
      border-top: 1px solid var(--border);
      padding: 4rem 5vw 2rem;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 3rem;
      margin-bottom: 3rem;
    }
    .footer-brand h3 {
      font-family: var(--font-display);
      font-size: 2.5rem;
      background: linear-gradient(90deg, var(--neon-violet), var(--neon-pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.8rem;
    }
    .footer-brand p {
      font-size: 0.85rem;
      color: var(--text-muted);
      max-width: 280px;
      line-height: 1.8;
    }
    .footer-col h4 {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1.2rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .footer-col ul li a {
      font-size: 0.88rem;
      color: var(--text-muted);
      transition: color 0.2s;
    }
    .footer-col ul li a:hover { color: var(--neon-pink); }
    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-bottom p {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }
    .social-links { display: flex; gap: 0.8rem; }
    .social-link {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: var(--bg-card);
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.9rem;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    }
    .social-link:hover {
      border-color: var(--neon-violet);
      box-shadow: var(--glow-v);
      transform: translateY(-2px);
    }

    /* ─── SCROLL ANIMATIONS ─────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.7s, transform 0.7s;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* ─── RESPONSIVE ────────────────────────────────────────── */
    @media (max-width: 900px) {
      .nav-links { display: none; }
      .burger { display: flex; }
      .about-inner { grid-template-columns: 1fr; }
      .about-visual { height: 280px; }
      .contact-inner { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr 1fr; }
      .vibes-grid {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto;
      }
      .vibe-item:first-child { grid-row: auto; }
    }
    @media (max-width: 600px) {
      .section-title { font-size: clamp(2.5rem, 10vw, 4rem); }
      .ticket-cards { grid-template-columns: 1fr; }
      .ticket-card.featured { transform: none; }
      .footer-top { grid-template-columns: 1fr; }
      .vibes-grid { grid-template-columns: 1fr; }
      .hero-title { font-size: clamp(4rem, 18vw, 7rem); }
      .countdown-sep { display: none; }
    }
  </style>
</head>
<body>

<!-- ─── NAV ──────────────────────────────────────────────── -->
<nav id="nav">
  <span class="nav-logo">BETTEFLY</span>
  <ul class="nav-links">
    <li><a href="#lineup">Line-up</a></li>
    <li><a href="#tickets">Billets</a></li>
    <li><a href="#vibes">Ambiance</a></li>
    <li><a href="#infos">Infos</a></li>
    <li><a href="#about">À propos</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="#tickets" class="nav-cta">🎟 Acheter</a></li>
  </ul>
  <button class="burger" onclick="document.querySelector('.mobile-menu').classList.add('open')" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu">
  <button class="mobile-close" onclick="this.closest('.mobile-menu').classList.remove('open')">✕</button>
  <a href="#lineup"  onclick="this.closest('.mobile-menu').classList.remove('open')">Line-up</a>
  <a href="#tickets" onclick="this.closest('.mobile-menu').classList.remove('open')">Billets</a>
  <a href="#vibes"   onclick="this.closest('.mobile-menu').classList.remove('open')">Ambiance</a>
  <a href="#infos"   onclick="this.closest('.mobile-menu').classList.remove('open')">Infos</a>
  <a href="#about"   onclick="this.closest('.mobile-menu').classList.remove('open')">À propos</a>
  <a href="#contact" onclick="this.closest('.mobile-menu').classList.remove('open')">Contact</a>
  <a href="#tickets" class="btn btn-primary" onclick="this.closest('.mobile-menu').classList.remove('open')">🎟 Acheter un billet</a>
</div>

<!-- ─── HERO ──────────────────────────────────────────────── -->
<section id="hero">
  <div class="hero-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="dot-blink"></span>
      13 Juin 2026 · Parc des Bords de Seine · Rueil-Malmaison
    </div>
    <h1 class="hero-title">
      <span class="grad-text">BETT</span><span style="color:var(--text-main)">E</span><span class="grad-text">FLY</span>
    </h1>
    <p class="hero-sub">Feel the Night. Live the Beat.</p>
    <p class="hero-desc">Un festival électro & pop au bord de la Seine. Une nuit inoubliable, une énergie collective, une scène qui vibre pour toi.</p>
    <div class="hero-ctas">
      <a href="#tickets" class="btn btn-primary">🎟&nbsp;Acheter un billet</a>
      <a href="#lineup"  class="btn btn-outline">🎵&nbsp;Voir le line-up</a>
    </div>
    <div class="countdown-wrapper">
      <div class="countdown-block">
        <span class="countdown-num" id="cd-days">00</span>
        <span class="countdown-label">Jours</span>
      </div>
      <span class="countdown-sep">:</span>
      <div class="countdown-block">
        <span class="countdown-num" id="cd-hours">00</span>
        <span class="countdown-label">Heures</span>
      </div>
      <span class="countdown-sep">:</span>
      <div class="countdown-block">
        <span class="countdown-num" id="cd-mins">00</span>
        <span class="countdown-label">Minutes</span>
      </div>
      <span class="countdown-sep">:</span>
      <div class="countdown-block">
        <span class="countdown-num" id="cd-secs">00</span>
        <span class="countdown-label">Secondes</span>
      </div>
    </div>
  </div>
  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<!-- ─── TICKER ────────────────────────────────────────────── -->
<div class="ticker-wrap" aria-hidden="true">
  <div class="ticker-inner" id="ticker">
    <span>⚡ BETTEFLY FESTIVAL</span>
    <span>🎉 13 JUIN 2026</span>
    <span>🌊 BORDS DE SEINE</span>
    <span>🎶 ÉLECTRO · POP · DJ SETS</span>
    <span>✨ RUEIL-MALMAISON</span>
    <span>🎟 PLACES LIMITÉES</span>
    <span>⚡ BETTEFLY FESTIVAL</span>
    <span>🎉 13 JUIN 2026</span>
    <span>🌊 BORDS DE SEINE</span>
    <span>🎶 ÉLECTRO · POP · DJ SETS</span>
    <span>✨ RUEIL-MALMAISON</span>
    <span>🎟 PLACES LIMITÉES</span>
  </div>
</div>

<!-- ─── LINEUP ────────────────────────────────────────────── -->
<section id="lineup">
  <div class="container">
    <div class="lineup-header reveal">
      <p class="section-label">Programmation 2026</p>
      <h2 class="section-title">Le <span class="grad-text">Line-Up</span><br>qui déchire.</h2>
      <p style="color:var(--text-muted);max-width:520px;margin:0 auto 2rem;">Des artistes soigneusement sélectionnés pour une nuit d'exception. De l'électro hypnotique à la pop electrisante.</p>
      <div class="stages-tabs">
        <button class="stage-tab active">🎤 Scène Principale</button>
        <button class="stage-tab">🎛 Scène DJ</button>
        <button class="stage-tab">🌿 Scène Ambient</button>
      </div>
    </div>
    <div class="artists-grid">
      <!-- Headliner -->
      <div class="artist-card reveal">
        <div class="artist-avatar av-1">SV</div>
        <span class="artist-badge badge-headliner">Headliner</span>
        <div class="artist-time">22:30 – 00:00 · Scène Principale</div>
        <div class="artist-name">SOLARVEX</div>
        <div class="artist-genre">Electronic / Future Bass / Live</div>
      </div>
      <div class="artist-card reveal reveal-delay-1">
        <div class="artist-avatar av-2">LN</div>
        <span class="artist-badge badge-headliner">Headliner</span>
        <div class="artist-time">20:30 – 22:00 · Scène Principale</div>
        <div class="artist-name">LUNA NOIRE</div>
        <div class="artist-genre">Electro Pop / Synthwave / FR</div>
      </div>
      <div class="artist-card reveal reveal-delay-2">
        <div class="artist-avatar av-3">KY</div>
        <span class="artist-badge badge-dj">DJ Set</span>
        <div class="artist-time">23:45 – 01:30 · Scène DJ</div>
        <div class="artist-name">DJ KRYOX</div>
        <div class="artist-genre">Techno / Minimal / Rave</div>
      </div>
      <div class="artist-card reveal">
        <div class="artist-avatar av-4">ZR</div>
        <span class="artist-badge badge-pop">Pop</span>
        <div class="artist-time">18:00 – 19:30 · Scène Principale</div>
        <div class="artist-name">ZOREA</div>
        <div class="artist-genre">Indie Pop / Dreamy / Bilingual</div>
      </div>
      <div class="artist-card reveal reveal-delay-1">
        <div class="artist-avatar av-5">NX</div>
        <span class="artist-badge badge-dj">DJ Set</span>
        <div class="artist-time">19:00 – 20:30 · Scène DJ</div>
        <div class="artist-name">NËXUS</div>
        <div class="artist-genre">House / Deep / Groove</div>
      </div>
      <div class="artist-card reveal reveal-delay-2">
